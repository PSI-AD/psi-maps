<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>PSI Maps Pro</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- ── Privacy Permission Strings (App Store Required) ─────────────────── -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PSI Maps Pro uses your location to show nearby luxury properties, calculate distances to amenities, and provide personalized map experiences.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PSI Maps Pro uses your location to show nearby luxury properties and send you alerts about new listings in your area.</string>

	<key>NSCameraUsageDescription</key>
	<string>PSI Maps Pro uses your camera for the AR View feature, which overlays property information on your real-world surroundings.</string>

	<key>NSPhotoLibraryUsageDescription</key>
	<string>PSI Maps Pro can save property photos and map screenshots to your photo library for future reference.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>PSI Maps Pro can save property images and brochures to your photo library.</string>

	<key>NSMicrophoneUsageDescription</key>
	<string>PSI Maps Pro uses the microphone for voice-based property search and AI assistant interactions.</string>

	<!-- ── Face ID / Biometric (future auth layer) ───────────────────────── -->
	<key>NSFaceIDUsageDescription</key>
	<string>PSI Maps Pro uses Face ID to quickly and securely access your saved properties and account.</string>

	<!-- ── iOS Safe Area (Capacitor WKWebView) ───────────────────────────── -->
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>

</dict>
</plist>
